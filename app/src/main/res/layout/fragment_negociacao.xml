<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/container_rodape"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        android:elevation="8dp"
        android:paddingHorizontal="@dimen/dimen_20"
        android:paddingTop="@dimen/dimen_12"
        android:paddingBottom="@dimen/dimen_20"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageView
            android:id="@+id/icone_variacao"
            android:layout_width="@dimen/dimen_20"
            android:layout_height="@dimen/dimen_20"
            android:alpha="0.6"
            android:contentDescription="@null"
            app:layout_constraintBottom_toBottomOf="@id/botao_finalizar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/botao_finalizar"
            app:srcCompat="@drawable/percent_discount_24px"
            app:tint="?attr/colorOnSurfaceVariant" />

        <TextView
            android:id="@+id/texto_valor_variacao"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dimen_8"
            android:text="@string/default_decimal_value"
            android:textColor="?attr/colorOnSurface"
            android:textSize="@dimen/text_22"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/icone_variacao"
            app:layout_constraintStart_toEndOf="@id/icone_variacao"
            app:layout_constraintTop_toTopOf="@id/icone_variacao" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/botao_finalizar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dimen_16"
            android:text="@string/finalizar"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/texto_valor_variacao"
            app:layout_constraintTop_toTopOf="parent"
            app:shapeAppearance="?attr/shapeAppearanceCornerSmall" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:scrollbars="none"
        android:layout_marginTop="@dimen/dimen_20"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/container_rodape"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/container_principal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/dimen_20"
            android:paddingTop="@dimen/dimen_20"
            android:paddingBottom="@dimen/dimen_20">

            <TextView
                android:id="@+id/texto_titulo_principal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="@string/title_main"
                android:textSize="@dimen/text_14" />

            <LinearLayout
                android:id="@+id/container_cabecalho"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/imagem_icone_frete"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:contentDescription="@null"
                    app:srcCompat="@drawable/handshake_24px" />

                <TextView
                    android:id="@+id/texto_titulo_frete"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/dimen_8"
                    android:text="@string/negocia_o"
                    android:textSize="20sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/container_metricas_lote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen_16"
                android:orientation="horizontal">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_peso_total"
                    style="?attr/materialCardViewFilledStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="@dimen/dimen_4"
                    app:cardBackgroundColor="?attr/colorPrimaryContainer"
                    app:shapeAppearance="?attr/shapeAppearanceCornerLarge">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="@dimen/dimen_16">

                        <ImageView
                            android:id="@+id/icone_peso_total"
                            android:layout_width="@dimen/dimen_20"
                            android:layout_height="@dimen/dimen_20"
                            android:alpha="0.7"
                            android:contentDescription="@null"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:srcCompat="@drawable/balance_24px"
                            app:tint="?attr/colorOnPrimaryContainer" />

                        <TextView
                            android:id="@+id/texto_rotulo_peso_medio"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/dimen_4"
                            android:alpha="0.8"
                            android:text="@string/card_label_peso_medio"
                            android:textAllCaps="true"
                            android:textColor="?attr/colorOnPrimaryContainer"
                            android:textSize="@dimen/text_10"
                            app:layout_constraintBottom_toBottomOf="@id/icone_peso_total"
                            app:layout_constraintStart_toEndOf="@id/icone_peso_total"
                            app:layout_constraintTop_toTopOf="@id/icone_peso_total" />

                        <TextView
                            android:id="@+id/texto_valor_peso_medio"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/dimen_4"
                            android:text="@string/default_decimal_value"
                            android:textColor="?attr/colorOnPrimaryContainer"
                            android:textSize="@dimen/text_22"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/icone_peso_total" />

                        <TextView
                            android:id="@+id/texto_unidade_peso_total"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/dimen_4"
                            android:text="@string/unit_kg"
                            android:textColor="?attr/colorOnPrimaryContainer"
                            android:textSize="@dimen/text_14"
                            app:layout_constraintBaseline_toBaselineOf="@id/texto_valor_peso_medio"
                            app:layout_constraintStart_toEndOf="@id/texto_valor_peso_medio" />

                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_quantidade_cabecas"
                    style="?attr/materialCardViewFilledStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/dimen_4"
                    app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
                    app:shapeAppearance="?attr/shapeAppearanceCornerLarge">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="@dimen/dimen_16">

                        <ImageView
                            android:id="@+id/icone_quantidade_cabecas"
                            android:layout_width="@dimen/dimen_20"
                            android:layout_height="@dimen/dimen_20"
                            android:alpha="0.7"
                            android:contentDescription="@null"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:srcCompat="@drawable/inventory_24px" />

                        <TextView
                            android:id="@+id/texto_rotulo_quantidade_cabecas"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/dimen_4"
                            android:alpha="0.7"
                            android:text="@string/card_label_cabecas"
                            android:textAllCaps="true"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="@dimen/text_10"
                            app:layout_constraintBottom_toBottomOf="@id/icone_quantidade_cabecas"
                            app:layout_constraintStart_toEndOf="@id/icone_quantidade_cabecas"
                            app:layout_constraintTop_toTopOf="@id/icone_quantidade_cabecas" />

                        <TextView
                            android:id="@+id/texto_valor_quantidade_cabecas"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/dimen_4"
                            android:text="@string/default_integer_value"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="@dimen/text_22"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/icone_quantidade_cabecas" />

                        <TextView
                            android:id="@+id/texto_unidade_quantidade_cabecas"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/dimen_4"
                            android:text="@string/card_suffix_head"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="@dimen/text_14"
                            app:layout_constraintBaseline_toBaselineOf="@id/texto_valor_quantidade_cabecas"
                            app:layout_constraintStart_toEndOf="@id/texto_valor_quantidade_cabecas" />

                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/campo_valor_frete"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen_16"
                android:hint="@string/hint_valor_frete_ex"
                app:shapeAppearance="?attr/shapeAppearanceCornerSmall"
                app:startIconDrawable="@drawable/payments_24px">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/entrada_texto_valor_frete"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:digits="0123456789,"
                    android:inputType="numberDecimal" />

            </com.google.android.material.textfield.TextInputLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen_10"
                android:orientation="horizontal">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/campo_valor_por_cab"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="@dimen/dimen_4"
                    android:hint="@string/hint_valor_por_cab"
                    app:shapeAppearance="?attr/shapeAppearanceCornerSmall"
                    app:startIconDrawable="@drawable/attach_money_24px">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/entrada_texto_valor_por_cab"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:digits="0123456789,"
                        android:inputType="numberDecimal" />

                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/campo_valor_por_kg"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/dimen_4"
                    android:hint="@string/hint_valor_por_kg"
                    app:shapeAppearance="?attr/shapeAppearanceCornerSmall"
                    app:startIconDrawable="@drawable/attach_money_24px">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/entrada_texto_valor_por_kg"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:digits="0123456789,"
                        android:inputType="numberDecimal" />

                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>

            <androidx.fragment.app.FragmentContainerView
                android:id="@+id/layout_container_valor_bezerro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen_10"
                android:visibility="gone"
                tools:layout="@layout/fragment_resumo_valores"
                tools:visibility="visible" />

            <androidx.fragment.app.FragmentContainerView
                android:id="@+id/layout_container_valor_frete"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen_10"
                android:visibility="gone"
                tools:layout="@layout/fragment_resumo_valores"
                tools:visibility="visible" />

            <androidx.fragment.app.FragmentContainerView
                android:id="@+id/layout_container_valor_bezerro_com_frete"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen_10"
                android:visibility="gone"
                tools:layout="@layout/fragment_resumo_valores"
                tools:visibility="visible" />

            <androidx.fragment.app.FragmentContainerView
                android:id="@+id/layout_container_valor_total_final"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen_10"
                android:visibility="gone"
                tools:layout="@layout/fragment_resultado"
                tools:visibility="visible" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>