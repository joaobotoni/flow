<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_container_resultados"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cartao_valor_total"
            style="?attr/materialCardViewFilledStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="?attr/colorPrimaryContainer"
            app:layout_constraintTop_toTopOf="parent"
            app:shapeAppearance="?attr/shapeAppearanceCornerLarge">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/dimen_20">

                <TextView
                    android:id="@+id/texto_rotulo_valor_total"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:alpha="0.8"
                    android:text="@string/card_label_total_value"
                    android:textAllCaps="true"
                    android:textColor="?attr/colorOnPrimaryContainer"
                    android:textSize="@dimen/text_11"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/texto_simbolo_moeda_total"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dimen_12"
                    android:text="@string/currency_symbol"
                    android:textColor="?attr/colorOnPrimaryContainer"
                    android:textSize="@dimen/text_18"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/texto_rotulo_valor_total" />

                <TextView
                    android:id="@+id/texto_valor_total"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/dimen_8"
                    android:text="@string/default_decimal_value"
                    android:textColor="?attr/colorOnPrimaryContainer"
                    android:textSize="@dimen/text_38"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="@id/texto_simbolo_moeda_total"
                    app:layout_constraintStart_toEndOf="@id/texto_simbolo_moeda_total"
                    app:layout_constraintTop_toTopOf="@id/texto_simbolo_moeda_total"
                    app:layout_constraintVertical_bias="0.5" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:id="@+id/linha_cards_valores"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen_8"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/cartao_valor_total">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cartao_valor_por_cabeca"
                style="?attr/materialCardViewFilledStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/dimen_4"
                android:layout_weight="1"
                app:cardBackgroundColor="?attr/colorPrimaryContainer"
                app:shapeAppearance="?attr/shapeAppearanceCornerLarge">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/dimen_16">

                    <TextView
                        android:id="@+id/texto_rotulo_valor_por_cabeca"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:alpha="0.8"
                        android:text="@string/card_label_unit_value"
                        android:textAllCaps="true"
                        android:textColor="?attr/colorOnPrimaryContainer"
                        android:textSize="@dimen/text_10"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/texto_simbolo_moeda_cabeca"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/currency_symbol"
                        android:textColor="?attr/colorOnPrimaryContainer"
                        android:textSize="@dimen/text_14"
                        app:layout_constraintBottom_toBottomOf="@id/texto_valor_por_cabeca"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="@id/texto_valor_por_cabeca"
                        app:layout_constraintVertical_bias="0.7" />

                    <TextView
                        android:id="@+id/texto_valor_por_cabeca"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/dimen_4"
                        android:layout_marginTop="@dimen/dimen_4"
                        android:text="@string/default_decimal_value"
                        android:textColor="?attr/colorOnPrimaryContainer"
                        android:textSize="@dimen/text_22"
                        android:textStyle="bold"
                        app:layout_constraintStart_toEndOf="@id/texto_simbolo_moeda_cabeca"
                        app:layout_constraintTop_toBottomOf="@id/texto_rotulo_valor_por_cabeca" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cartao_valor_por_kg"
                style="?attr/materialCardViewFilledStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/dimen_4"
                android:layout_weight="1"
                app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
                app:shapeAppearance="?attr/shapeAppearanceCornerLarge">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/dimen_16">

                    <TextView
                        android:id="@+id/texto_rotulo_valor_por_kg"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:alpha="0.7"
                        android:text="@string/card_label_valor_por_kg"
                        android:textAllCaps="true"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="@dimen/text_10"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/texto_simbolo_moeda_kg"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/currency_symbol"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="@dimen/text_14"
                        app:layout_constraintBottom_toBottomOf="@id/texto_valor_por_kg"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="@id/texto_valor_por_kg"
                        app:layout_constraintVertical_bias="0.7" />

                    <TextView
                        android:id="@+id/texto_valor_por_kg"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/dimen_4"
                        android:layout_marginTop="@dimen/dimen_4"
                        android:text="@string/default_decimal_value"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="@dimen/text_22"
                        android:textStyle="bold"
                        app:layout_constraintStart_toEndOf="@id/texto_simbolo_moeda_kg"
                        app:layout_constraintTop_toBottomOf="@id/texto_rotulo_valor_por_kg" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>